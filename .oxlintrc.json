{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "warn",
        "suspicious": "warn"
    },
    "env": {
        "browser": true,
        "node": true
    },
    "ignorePatterns": [".nuxt", ".output", "dist", "node_modules", "public"],
    "rules": {
        "no-undef": "off",
        "no-underscore-dangle": "off"
    }
}
